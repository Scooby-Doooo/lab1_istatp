@model BookSwap.Mvc.Models.Transaction

@{
    ViewData["Title"] = "Створення";
}

<h1>Створення</h1>

<h4>Транзакція</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="RequesterId" class="control-label"></label>
                <select asp-for="RequesterId" class ="form-control" asp-items="ViewBag.RequesterId"></select>
            </div>
            <div class="form-group">
                <label asp-for="TargetItemId" class="control-label"></label>
                <select asp-for="TargetItemId" class ="form-control" asp-items="ViewBag.TargetItemId"></select>
            </div>
            <div class="form-group">
                <input type="submit" value="Створити" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Повернутися до списку</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
